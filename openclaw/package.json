{
  "schema_version": 1,
  "name": "openclaw",
  "version": "0.1.3",
  "description": "OpenClaw plugin and matching nono profile. Provides sandbox-aware diagnostics on permission failures and ships the openclaw profile via the registry.",
  "license": "Apache-2.0",
  "platforms": ["macos", "linux"],
  "min_nono_version": "0.47.0",
  "artifacts": [
    { "type": "profile", "path": "policy.json", "install_as": "openclaw" },
    { "type": "plugin", "path": "README.md" },
    { "type": "plugin", "path": ".openclaw-plugin/plugin.json" },
    { "type": "plugin", "path": "settings.json" },
    { "type": "plugin", "path": "bin/nono-hook.sh" },
    { "type": "plugin", "path": "skills/nono-sandbox/SKILL.md" },
    { "type": "plugin", "path": "nono-hooks/openclaw.plugin.json" },
    { "type": "plugin", "path": "nono-hooks/index.js" },
    { "type": "plugin", "path": "wiring/marketplace.json" },
    { "type": "plugin", "path": "wiring/known-marketplaces.json" },
    { "type": "plugin", "path": "wiring/installed-plugin.json" }
  ],
  "wiring": [
    {
      "type": "symlink",
      "link": "$HOME/.openclaw/plugins/marketplaces/$NS/plugins/nono",
      "target": "$PACK_DIR"
    },
    {
      "type": "symlink",
      "link": "$HOME/.openclaw/plugins/marketplaces/$NS/plugins/nono-hooks",
      "target": "$PACK_DIR/nono-hooks"
    },
    {
      "type": "symlink",
      "link": "$HOME/.openclaw/plugins/cache/$NS/nono-hooks/1.0.0",
      "target": "$PACK_DIR/nono-hooks"
    },
    {
      "type": "write_file",
      "source": "wiring/marketplace.json",
      "dest": "$HOME/.openclaw/plugins/marketplaces/$NS/.openclaw-plugin/marketplace.json"
    },
    {
      "type": "symlink",
      "link": "$HOME/.openclaw/plugins/cache/$NS/nono/1.0.0",
      "target": "$PACK_DIR"
    },
    {
      "type": "json_merge",
      "file": "$HOME/.openclaw/plugins/known_marketplaces.json",
      "patch": "wiring/known-marketplaces.json"
    },
    {
      "type": "json_merge",
      "file": "$HOME/.openclaw/plugins/installed_plugins.json",
      "patch": "wiring/installed-plugin.json"
    }
  ]
}
