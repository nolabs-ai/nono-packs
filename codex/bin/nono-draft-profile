#!/usr/bin/env python3
"""Create a nono profile draft for Codex sandbox capability extensions."""

from __future__ import annotations

import argparse
import hashlib
import json
import os
import re
import sys
from pathlib import Path


VALID_NAME = re.compile(r"^[A-Za-z0-9_.-]+$")
FIELDS = ("read", "write", "allow", "read_file", "write_file", "allow_file")


def expand_path(value: str) -> str:
    return str(Path(os.path.expandvars(os.path.expanduser(value))).resolve())


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Write ~/.config/nono/profile-drafts/<name>.json"
    )
    parser.add_argument("--name", required=True, help="draft profile name")
    parser.add_argument("--extends", required=True, dest="extends_profile")
    group = parser.add_mutually_exclusive_group(required=True)
    for field in FIELDS:
        group.add_argument(f"--{field.replace('_', '-')}", metavar="PATH")
    return parser.parse_args()


def main() -> int:
    args = parse_args()

    if not VALID_NAME.fullmatch(args.name):
        print(f"invalid profile draft name: {args.name!r}", file=sys.stderr)
        return 2
    if not VALID_NAME.fullmatch(args.extends_profile):
        print(f"invalid extends profile name: {args.extends_profile!r}", file=sys.stderr)
        return 2

    selected_field = None
    selected_path = None
    for field in FIELDS:
        value = getattr(args, field)
        if value:
            selected_field = field
            selected_path = expand_path(value)
            break

    if not selected_field or not selected_path:
        print("one filesystem grant is required", file=sys.stderr)
        return 2

    config_home = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config"))
    nono_config = config_home / "nono"
    draft_dir = nono_config / "profile-drafts"
    draft_dir.mkdir(parents=True, exist_ok=True)
    draft_path = draft_dir / f"{args.name}.json"
    base_path = draft_dir / f"{args.name}.base"
    target_path = nono_config / "profiles" / f"{args.name}.json"

    profile = {
        "extends": args.extends_profile,
        "meta": {"name": args.name, "version": "1.0.0"},
        "filesystem": {selected_field: [selected_path]},
    }

    draft_path.write_text(json.dumps(profile, indent=2) + "\n")
    if target_path.is_file():
        base_path.write_text(hashlib.sha256(target_path.read_bytes()).hexdigest() + "\n")
    elif base_path.exists():
        base_path.unlink()

    print(f"Drafted {draft_path}")
    if target_path.is_file():
        print(f"Wrote base hash {base_path}")
    print(f"Run: nono profile promote {args.name}")
    print(f"Then restart with: nono run --profile {args.name} -- codex")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
