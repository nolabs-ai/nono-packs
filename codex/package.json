{
  "schema_version": 1,
  "name": "codex",
  "version": "0.1.3",
  "description": "Teaches OpenAI Codex how to work inside a nono security sandbox.",
  "license": "Apache-2.0",
  "platforms": ["macos", "linux"],
  "min_nono_version": "0.64.1",
  "artifacts": [
    { "type": "profile", "path": "policy.json", "install_as": "codex" },
    { "type": "plugin", "path": ".codex-plugin/plugin.json" },
    { "type": "plugin", "path": "bin/nono-draft-profile" },
    { "type": "plugin", "path": "bin/nono-hook.sh" },
    { "type": "plugin", "path": "bin/nono-hook-session.sh" },
    { "type": "plugin", "path": "skills/nono-sandbox/SKILL.md" },
    { "type": "plugin", "path": "assets/logo.png" },
    { "type": "plugin", "path": "wiring/marketplace.json" },
    { "type": "plugin", "path": "wiring/codex-block.toml" },
    { "type": "plugin", "path": "wiring/profile-drafts-dir-marker" }
  ],
  "wiring": [
    {
      "type": "write_file",
      "source": "wiring/profile-drafts-dir-marker",
      "dest": "$NONO_CONFIG/profile-drafts/.nono-codex-pack-marker"
    },
    {
      "type": "write_file",
      "source": "bin/nono-draft-profile",
      "dest": "$HOME/.codex/bin/nono-draft-profile"
    },
    {
      "type": "symlink",
      "link": "$HOME/.codex/plugins/marketplaces/$NS/plugins/nono",
      "target": "$PACK_DIR"
    },
    {
      "type": "write_file",
      "source": "wiring/marketplace.json",
      "dest": "$HOME/.codex/plugins/marketplaces/$NS/.agents/plugins/marketplace.json"
    },
    {
      "type": "symlink",
      "link": "$HOME/.codex/plugins/cache/$NS/nono/local",
      "target": "$PACK_DIR"
    },
    {
      "type": "toml_block",
      "file": "$HOME/.codex/config.toml",
      "marker_id": "always-further-codex",
      "content": "wiring/codex-block.toml",
      "position": "top"
    }
  ]
}
