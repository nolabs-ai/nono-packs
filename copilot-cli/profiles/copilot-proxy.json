{
  "extends": "copilot-base",
  "meta": {
    "name": "copilot-cli-proxy",
    "version": "0.1.0",
    "description": "profile for sandboxed GitHub Copilot CLI session. Session authentication done via credential injection from local OS keychain."
  },
  "groups": {
    "include": [
      "claude_code_macos"
    ]
  },
  "network": {
    "proxy_credentials": ["copilot_cli"],
    "custom_credentials": {
      "copilot_cli": {
        "upstream": "https://github.com",
        "credential_key": "copilot_github_token",
        "inject_header": "Authorization",
        "credential_format": "Token {}"
      }
    }
  }
}
