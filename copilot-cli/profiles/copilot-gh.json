{
  "extends": "copilot-base",
  "meta": {
    "name": "copilot-cli",
    "version": "0.1.0",
    "description": "profile for sandboxed GitHub Copilot CLI session. Session authentication done via gh.",
    "author": "always-further"
  },
  "groups": {
    "include": [
      "node_runtime"
    ]
  },
  "filesystem": {
    "write": [
      "$HOME/Library/Keychains"
    ],
    "read_file": [
      "$HOME/Library/Keychains/login.keychain-db"
    ],
    "bypass_protection": [
      "$HOME/Library/Keychains"
    ],
    "read": [
      "/usr/local/etc/gitconfig"
    ]
  }
}
