{
  "extends": [
    "default"
  ],
  "meta": {
    "name": "antigravity",
    "version": "1.0.0",
    "description": "Runtime-discovered path additions for agy",
    "author": null
  },
  "security": {
    "signal_mode": null,
    "process_info_mode": null,
    "ipc_mode": null,
    "capability_elevation": null,
    "wsl2_proxy_policy": null
  },
  "groups": {
    "include": [],
    "exclude": []
  },
  "commands": {
    "allow": [],
    "deny": []
  },
  "filesystem": {
    "allow": [
      "~/.gemini/antigravity-cli"
    ],
    "read": [
      "~/.gemini",
      "~/.gemini/antigravity-cli/log",
      "~/go/src",
      "~/Library/Caches/ms-playwright-go/1.57.0",
      "~/dev/nono-workspace/nono-packs-demo",
