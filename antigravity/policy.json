    "listen_port": [],
    "connect_port": [],
    "custom_credentials": {},
    "upstream_proxy": null,
    "upstream_bypass": []
  },
  "diagnostics": {
    "suppress_system_services": []
  },
  "linux": {
    "af_unix_mediation": null
  },
  "env_credentials": {},
  "environment": null,
  "workdir": {
    "access": "none"
  },
  "hooks": {},
  "session_hooks": {},
  "rollback": {
    "exclude_patterns": [],
    "exclude_globs": []
  },
  "open_urls": {
    "allow_origins": [
      "https://accounts.google.com"
    ],
    "allow_localhost": true
  },
  "allow_launch_services": null,
  "allow_gpu": null,
  "allow_parent_of_protected": null,
  "interactive": false,
  "skipdirs": [],
